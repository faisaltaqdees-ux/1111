# .env.local - Local Development Environment (Never commit this file)
# ========================================================================
# This file is for LOCAL DEVELOPMENT ONLY with throwaway test wallets.
# Never use wallets containing real funds on testnet or mainnet.
# Always add .env.local to .gitignore

# 1. Create a throwaway wallet for local testing:
#    - Install MetaMask: https://metamask.io
#    - Create a new account
#    - Get test WIRE from faucet: https://faucet.wirefluid.com
#    - Export private key: Account Menu → Account Details → Show Private Key

# 2. Copy this file to .env.local and fill in the placeholder:
#    cp .env.local.example .env.local

# 3. Replace DEPLOYER_PRIVATE_KEY with your throwaway wallet's private key
#    (Only for local testing, never production)

DEPLOYER_PRIVATE_KEY=0x

# 3. Optional: Override RPC endpoint (default is fine for testnet)
# WIREFLUID_RPC_URL=https://evm.wirefluid.com

# 4. Contract addresses (update after deployment)
# NEXT_PUBLIC_MARKET_ADDRESS=0x
# NEXT_PUBLIC_BADGE_ADDRESS=0x
# NEXT_PUBLIC_TICKET_ADDRESS=0x

# 5. Oracle private key (for local oracle testing)
# ORACLE_PRIVATE_KEY=0x

# 6. Database (optional - for payment processing testing)
# DATABASE_URL=postgresql://user:password@localhost:5432/pslpulse
